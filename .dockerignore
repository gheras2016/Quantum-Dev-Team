# Keep the build context small and never bake secrets or dev artefacts in.

# VCS / IDE
.git
.github
.gitignore
.gitattributes
.editorconfig
.vscode
.idea

# Dependencies & build output (rebuilt inside the image)
node_modules
vendor
public/build
public/hot
public/storage

# Secrets & local environment
.env
.env.*
!.env.example

# Local/dev database — never ship it (production uses PostgreSQL)
database/database.sqlite

# Stale framework caches
bootstrap/cache/*.php
storage/logs/*
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
storage/app/public/*

# Tests & docs (not needed at runtime)
tests
phpunit.xml
*.md

# Docker files themselves
Dockerfile
.dockerignore
