# ---------------------------------------------------------------------------
# Reference environment for a production (Render/Docker) deployment.
# These are set as environment variables on the host (Render dashboard or
# render.yaml) — NOT committed as a real .env file.
# ---------------------------------------------------------------------------

APP_NAME="Quantum Dev Team"
APP_ENV=production
APP_DEBUG=false
# Generate with:  php artisan key:generate --show
APP_KEY=
APP_URL=https://your-app.onrender.com

# Send logs to the container output so Render can capture them.
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# --- PostgreSQL -------------------------------------------------------------
# Either provide a single DATABASE_URL (Render sets this from the database),
# or the individual DB_* values below.
DB_CONNECTION=pgsql
DATABASE_URL=postgres://user:password@host:5432/database
# DB_HOST=
# DB_PORT=5432
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=

# --- Runtime services -------------------------------------------------------
SESSION_DRIVER=file
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public

# --- Cloudinary (persistent image/logo storage) -----------------------------
# Render's filesystem is ephemeral, so uploads should go to Cloudinary.
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# If left empty, uploads fall back to the (ephemeral) local disk.
CLOUDINARY_URL=

# --- Mail (configure a real SMTP provider for production email) -------------
MAIL_MAILER=log
# MAIL_HOST=
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="no-reply@your-domain.com"
# MAIL_FROM_NAME="${APP_NAME}"

# Run `php artisan migrate --force` on container start.
RUN_MIGRATIONS=true
